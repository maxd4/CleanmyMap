{
  "name": "cleanmymap-monorepo",
  "version": "1.0.0",
  "description": "Monorepo de la plateforme CleanMyMap.fr",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node scripts/dev-with-fallback-port.mjs",
    "clean:temp": "node scripts/clean-local-temp.mjs",
    "clean:temp:force": "node scripts/clean-local-temp.mjs --force",
    "dev:clean": "node scripts/clean-dev-cache.mjs && node scripts/clean-local-temp.mjs && npm run dev",
    "dev:strict": "DEV_STRICT_PORT=1 node scripts/dev-with-fallback-port.mjs",
    "build": "npm run build -w apps/web",
    "lint": "npm run lint -w apps/web",
    "lint:audit": "node scripts/lint-audit-direct.js",
    "security:secrets": "node scripts/secret-audit.mjs",
    "audit:vercel-quota": "node scripts/audit-vercel-quota.mjs",
    "report:vercel-surface": "node scripts/generate-vercel-surface-report.mjs",
    "audit:vercel:api-routes": "node scripts/audit-vercel-surface.mjs list-api-routes",
    "audit:vercel:dynamic-pages": "node scripts/audit-vercel-surface.mjs list-dynamic-pages",
    "audit:vercel:force-dynamic": "node scripts/audit-vercel-surface.mjs list-force-dynamic",
    "audit:vercel:revalidate-zero": "node scripts/audit-vercel-surface.mjs list-revalidate-zero",
    "audit:vercel:no-store": "node scripts/audit-vercel-surface.mjs list-no-store",
    "audit:vercel:cookies": "node scripts/audit-vercel-surface.mjs list-cookies",
    "audit:vercel:headers": "node scripts/audit-vercel-surface.mjs list-headers",
    "audit:vercel:auth": "node scripts/audit-vercel-surface.mjs list-auth",
    "audit:vercel:heavy-imports": "node scripts/audit-vercel-surface.mjs list-heavy-imports",
    "audit:vercel:polling": "node scripts/audit-vercel-surface.mjs list-polling",
    "audit:vercel:external-fetches": "node scripts/audit-vercel-surface.mjs list-external-fetches",
    "audit:supabase:quota": "npm run backend:supabase:quota-audit -w apps/web",
    "audit:quiz-quality": "node --experimental-strip-types scripts/audit-quiz-quality.mjs",
    "audit:quiz-sources": "node --experimental-strip-types scripts/audit-quiz-sources.mjs",
    "audit:vercel:ci": "node scripts/audit-vercel-ci.mjs",
    "typecheck": "npm run typecheck -w apps/web",
    "check:doc-visuals": "node scripts/check-doc-visuals.mjs",
    "check:doc-governance": "node scripts/check-documentation-governance.mjs",
    "check:utf8-fr": "node scripts/check-utf8-fr-files.mjs",
    "check:lockfile-policy": "node scripts/check-lockfile-policy.mjs",
    "check:stack-doc-drift": "node scripts/check-stack-doc-drift.mjs",
    "check:agent-skills": "node scripts/check-agent-skill-mirrors.mjs",
    "audit:pages-site-drift": "node scripts/check-pages-site-route-drift.mjs",
    "check:pages-site-drift": "node scripts/check-pages-site-route-drift.mjs --strict",
    "quality:top-heavy": "node scripts/check-top-heavy-files.mjs --enforce",
    "check:root-files": "node scripts/check-root-file-hygiene.mjs",
    "analyze:heavy-files": "node scripts/analyze-heavy-files.mjs",
    "data:export:clerk": "node scripts/export-clerk-users.mjs",
    "data:audit:clerk-supabase": "node scripts/audit-clerk-supabase.mjs",
    "report:normalize-language": "node scripts/normalize-report-language.mjs",
    "report:normalize-typography": "node scripts/normalize-scientific-typography.mjs",
    "report:stats": "node scripts/update-audit-stats.mjs",
    "report:split-bibliography": "node scripts/split-bibliography.mjs",
    "design-system:board": "node scripts/generate-design-system-board.mjs",
    "design-system:board:watch": "node scripts/generate-design-system-board.mjs --watch",
    "pre-release:check": "node scripts/pre-release-check.mjs --exit-on-error",
    "metrics:cicd": "node scripts/cicd-metrics-report.mjs",
    "metrics:jsonl": "node scripts/summarize-jsonl.mjs",
    "modularize:report": "node scripts/generate-modularization-report.mjs",
    "test": "npm run test -w apps/web",
    "test:security": "npm run test:security -w apps/web",
    "test:regression-gates": "npm run test:regression-gates -w apps/web",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "companion:typecheck": "npm --prefix companion-app run typecheck",
    "precommit:guard": "powershell -ExecutionPolicy Bypass -File scripts/pre_push_guard.ps1",
    "prepush:guard": "powershell -ExecutionPolicy Bypass -File scripts/pre_push_guard.ps1",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File scripts/install_git_hooks.ps1",
    "checks:changed:quick": "powershell -ExecutionPolicy Bypass -File scripts/check_changed_quick.ps1",
    "checks:changed:quick:build": "powershell -ExecutionPolicy Bypass -File scripts/check_changed_quick.ps1 -IncludeBuild",
    "checks:changed": "powershell -ExecutionPolicy Bypass -File scripts/run_checks.ps1 -Scope changed",
    "checks:full": "powershell -ExecutionPolicy Bypass -File scripts/run_checks.ps1 -Scope full",
    "checks:maintenance:changed": "powershell -ExecutionPolicy Bypass -File scripts/run_checks.ps1 -Scope changed",
    "checks:maintenance": "powershell -ExecutionPolicy Bypass -File scripts/run_checks.ps1 -Scope full",
    "checks:maintenance:full": "powershell -ExecutionPolicy Bypass -File scripts/run_checks.ps1 -Scope full",
    "checks:global": "powershell -ExecutionPolicy Bypass -File scripts/run_checks2.ps1 -Scope full",
    "checks:global:e2e": "powershell -ExecutionPolicy Bypass -File scripts/run_checks2.ps1 -Scope full -IncludeE2E",
    "checks:changed:e2e": "powershell -ExecutionPolicy Bypass -File scripts/run_checks2.ps1 -Scope changed -IncludeE2E",
    "checks:full:e2e": "powershell -ExecutionPolicy Bypass -File scripts/run_checks2.ps1 -Scope full -IncludeE2E",
    "checks": "powershell -ExecutionPolicy Bypass -File scripts/run_checks2.ps1 -Scope full",
    "maintenance:check": "npm run checks:maintenance",
    "session:bootstrap": "node scripts/session_bootstrap.mjs",
    "session:close": "node scripts/update_session_memory.mjs",
    "session:budget": "node scripts/context-budget-check.mjs",
    "screenshots": "node documentation/liberte-UX-UI/capture-pages.mjs",
    "screenshots:screen": "node documentation/pages_site/screen/capture-pages.mjs",
    "audit:supabase-migration-trees": "node scripts/audit-supabase-migration-trees.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxd4/CleanMyMap.git"
  },
  "keywords": [
    "cleanmymap",
    "nextjs",
    "monorepo"
  ],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/maxd4/CleanMyMap/issues"
  },
  "homepage": "https://github.com/maxd4/CleanMyMap#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.59.1",
    "sharp": "^0.35.3"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.2.0",
    "@rollup/rollup-linux-x64-gnu": "4.62.2",
    "@sentry/cli-linux-x64": "3.6.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "dompurify": "3.4.11",
    "fast-uri": "3.1.2",
    "ajv": {
      "fast-uri": "3.1.2"
    },
    "js-yaml": "5.2.1",
    "postcss": "8.5.10",
    "protobufjs": "7.6.5",
    "brace-expansion": "5.0.6",
    "js-cookie": "3.0.8",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "ws": "8.21.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "uuid": "11.1.1"
  },
  "dependencies": {
    "posthog-js": "^1.404.1",
    "posthog-node": "^5.45.2"
  }
}
