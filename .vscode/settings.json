{
  "files.autoSave": "onFocusChange",
  "editor.fontSize": 12,
  "typescript.tsserver.maxTsServerMemory": 2048,
  "typescript.disableAutomaticTypeAcquisition": true,
  "files.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/.next-sourcemap-test": true,
    "**/.vercel": true,
    "**/artifacts": true,
    "**/build": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/backups": true,
    "**/scratch": true
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.next/**": true,
    "**/.next-sourcemap-test/**": true,
    "**/.vercel/**": true,
    "**/artifacts/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/backups/**": true,
    "**/scratch/**": true,
    "**/companion-app/node_modules/**": true,
    "**/companion-app/**": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/.next-sourcemap-test": true,
    "**/.vercel": true,
    "**/artifacts": true,
    "**/build": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/backups": true,
    "**/scratch": true,
    "**/companion-app/node_modules": true,
    "**/companion-app": true
  }
}
