# Copy this file to `.env.local` for the local-only Clerk profile.
# It is designed for localhost development with the IMU bypass enabled.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_anon_placeholder
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PROXY_URL=
NEXT_PUBLIC_CONTACT_EMAIL=contact@cleanmymap.fr
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_TOKEN=phc_placeholder_legacy
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_REGION=eu
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

CLERK_SECRET_KEY=sk_test_placeholder
# Standard Clerk production domain (Vercel-managed): auth.cleanmymap.fr
CLERK_DOMAIN=
CLERK_IS_SATELLITE=0
CLERK_SATELLITE_AUTO_SYNC=1
CLERK_ADMIN_USER_IDS=
CLERK_MAX_USER_IDS=
CLERK_ALLOWED_PARTIES=

# Note: `app_...` is the Clerk application ID shown in the dashboard.
# It is not a secret key and it does not belong in `.env.local`.
# Google OAuth is configured in the Clerk Dashboard, not in repo env files.
# Keep the Google Client ID / Client Secret there, and use this redirect URI:
# https://clerk.auth.cleanmymap.fr/v1/oauth_callback
# Required for feedback persistence, creator inbox sync and admin writes.
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_placeholder
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=
# Required for creator inbox notifications and public contact mail flows.
EMAIL_FROM="CleanMyMap <noreply@cleanmymap.fr>"
CONTACT_EMAIL=contact@cleanmymap.fr
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
CREATOR_INBOX_EMAIL=contact@cleanmymap.fr
SUPABASE_STORAGE_QUOTA_BYTES=
SUPABASE_STORAGE_QUOTA_GB=
CRON_SECRET=
VISION_TRAINING_ENABLED=0
RESEND_TEST_TOKEN=
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
PINECONE_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
UPTIMEROBOT_API_KEY=
CLOUDFLARE_API_TOKEN=
ALLOW_LOCAL_FILE_STORE_FALLBACK=0
ALLOW_LOCAL_ACTION_STORE_IN_PROD=0
IMPACT_PROXY_VERSION=
IMPACT_PROXY_WATER_LITERS_PER_CIGARETTE_BUTT=
IMPACT_PROXY_CO2_KG_PER_WASTE_KG=
IMPACT_PROXY_SURFACE_M2_PER_WASTE_KG=
IMPACT_PROXY_SURFACE_M2_PER_VOLUNTEER_MINUTE=
CMM_DEV_AUTH_BYPASS=1
CMM_DEV_AUTH_BYPASS_ROLE=max
CMM_DEV_AUTH_BYPASS_DISPLAY_NAME=Local preview
CMM_DEV_AUTH_BYPASS_USERNAME=local-preview
CMM_DEV_AUTH_BYPASS_USER_ID=dev-localhost
