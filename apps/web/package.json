{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/dev-with-fallback-port.mjs",
    "build": "node scripts/ensure-deterministic-routes-manifest.mjs --prepare && next build && node scripts/ensure-deterministic-routes-manifest.mjs --finalize && node scripts/upload-sentry-sourcemaps.mjs",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "npx tsc --noEmit --pretty false --skipLibCheck",
    "test": "vitest run",
    "test:security": "vitest run src/lib/security/validation.test.ts src/lib/security/indexation-invariants.test.ts src/lib/seo/indexability.test.ts src/lib/auth/protected-routes.test.ts src/lib/community/discussion-rate-limit.test.ts src/proxy.protected-routes.test.ts src/proxy.app-shell.test.ts src/app/api/public-form-security.test.ts src/app/api/api-boundary.test.ts src/app/api/notifications/route.test.ts src/app/api/actions/route.submit.test.ts src/app/api/account/display-mode/route.test.ts src/app/api/account/profile-role/route.test.ts",
    "test:regression-gates": "vitest run src/lib/actions/contract-regression-gates.test.ts src/lib/sections-registry.invariants.test.ts src/lib/navigation.registry-consistency.test.ts src/lib/vercel-regression-gates.test.ts src/proxy.protected-routes.test.ts",
    "backup:actions": "node scripts/export-actions-backup.mjs",
    "import:actions": "node scripts/import-actions-backup.mjs",
    "data:test:build": "node scripts/build-test-local-store.mjs",
    "data:real:sync": "node scripts/sync-real-data-from-sheet.mjs --geocode",
    "data:sheet:build-import": "node scripts/build-admin-import-from-sheet.mjs",
    "data:sheet:sync-supabase": "node --experimental-strip-types scripts/sync-google-sheet-to-supabase.mjs --geocode",
    "data:geometry:backfill": "node --experimental-strip-types scripts/backfill-derived-geometry.mjs",
    "data:sheet:push": "node scripts/push-google-sheet-from-form-like.mjs",
    "data:validated:sync": "node scripts/sync-validated-local-store.mjs",
    "data:archive:supabase": "node scripts/export-supabase-archive.mjs",
    "data:cleanup:supabase": "node scripts/cleanup-supabase-retention.mjs",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "backend:doctor": "node scripts/backend-doctor.mjs",
    "backend:supabase:advisors": "node scripts/supabase-security-advisors.mjs",
    "backend:supabase:advisors:local": "node scripts/supabase-security-advisors.mjs --local",
    "backend:supabase:advisors:linked": "node scripts/supabase-security-advisors.mjs --linked",
    "backend:supabase:quota-audit": "node scripts/supabase-quota-audit.mjs",
    "backend:supabase:quota-audit:db": "node scripts/supabase-quota-audit.mjs --with-db",
    "backend:vercel:env:sync": "node scripts/vercel-sync-env.mjs --file=.env.local --environments=development,production",
    "backend:supabase:push": "npx supabase db push --workdir . --yes",
    "backend:bootstrap": "node scripts/backend-bootstrap.mjs",
    "gamification:backfill:actions": "node scripts/backfill-action-gamification.mjs"
  },
  "dependencies": {
    "@clerk/localizations": "^4.6.0",
    "@clerk/nextjs": "7.3.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.105.3",
    "@types/react-big-calendar": "^1.16.3",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^1.14.0",
    "next": "16.2.9",
    "posthog-js": "^1.373.4",
    "posthog-node": "^5.33.7",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "stripe": "^22.1.0",
    "swiper": "^12.1.4",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.5"
  }
}
