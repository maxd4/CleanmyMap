{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/ensure-deterministic-routes-manifest.mjs --prepare && next build && node scripts/ensure-deterministic-routes-manifest.mjs --finalize",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "npx tsc --noEmit --pretty false --skipLibCheck",
    "test": "vitest run",
    "test:regression-gates": "vitest run src/lib/actions/contract-regression-gates.test.ts src/lib/sections-registry.invariants.test.ts src/lib/navigation.registry-consistency.test.ts src/proxy.protected-routes.test.ts",
    "backup:actions": "node scripts/export-actions-backup.mjs",
    "import:actions": "node scripts/import-actions-backup.mjs",
    "data:test:build": "node scripts/build-test-local-store.mjs",
    "data:real:sync": "node scripts/sync-real-data-from-sheet.mjs --geocode",
    "data:sheet:build-import": "node scripts/build-admin-import-from-sheet.mjs",
    "data:sheet:sync-supabase": "node --experimental-strip-types scripts/sync-google-sheet-to-supabase.mjs --geocode",
    "data:geometry:backfill": "node --experimental-strip-types scripts/backfill-derived-geometry.mjs",
    "data:sheet:push": "node scripts/push-google-sheet-from-form-like.mjs",
    "data:validated:sync": "node scripts/sync-validated-local-store.mjs",
    "backend:doctor": "node scripts/backend-doctor.mjs",
    "backend:vercel:env:sync": "node scripts/vercel-sync-env.mjs --file=.env.local --environments=development,production",
    "backend:supabase:push": "npx supabase db push --workdir . --yes",
    "backend:bootstrap": "node scripts/backend-bootstrap.mjs"
  },
  "dependencies": {
    "@clerk/localizations": "^4.5.2",
    "@clerk/nextjs": "7.2.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/supabase-js": "^2.101.1",
    "@types/react-big-calendar": "^1.16.3",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^0.474.0",
    "next": "16.2.4",
    "posthog-js": "^1.364.6",
    "posthog-node": "^5.28.11",
    "react": "19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "stripe": "^21.0.1",
    "swiper": "^12.1.3",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
