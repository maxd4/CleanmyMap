{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["cdg1"],
  "build": {
    "env": {
      "NEXT_PUBLIC_SOURCE_MAP": "true"
    }
  },
  "rewrites": [
    {
      "source": "/docs/visuels-rapport/data_pipeline.png",
      "destination": "/docs/visuels-rapport/data_pipeline.webp"
    },
    {
      "source": "/docs/visuels-rapport/ecosystem_overview.png",
      "destination": "/docs/visuels-rapport/ecosystem_overview.webp"
    },
    {
      "source": "/docs/visuels-rapport/monorepo_structure.png",
      "destination": "/docs/visuels-rapport/monorepo_structure.webp"
    },
    {
      "source": "/docs/visuels-rapport/security_architecture.png",
      "destination": "/docs/visuels-rapport/security_architecture.webp"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/storage-usage",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/environmental-impact",
      "schedule": "0 3 * * *"
    }
  ],
  "ignoreCommand": "node -e \"process.exit((process.env.VERCEL_GIT_COMMIT_REF || '').startsWith('dependabot/') ? 0 : 1)\""
}
