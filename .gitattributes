# Forcer Git à traiter les fichiers comme UTF-8 et à ne pas corrompre les fins de lignes
* text=auto eol=lf

# Fichiers spécifiques devant rester en UTF-8 sans conversion locale Windows destructrice
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf

# Fichiers binaires
*.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.zip binary
