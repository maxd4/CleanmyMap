# Variables d'environnement — companion-app (Expo / React Native)
# Copier ce fichier en `.env` et remplir les valeurs.
# Ne jamais committer le fichier .env (il est dans .gitignore).

# ─── Supabase ─────────────────────────────────────────────────────────────────
# URL du projet Supabase (visible dans Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co

# Clé anon publique (visible dans Settings > API > Project API keys)
# ⚠️  Ne jamais utiliser la clé service_role ici — elle est privée et donne accès total.
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Notes ────────────────────────────────────────────────────────────────────
# Ces valeurs SONT les mêmes que celles utilisées par apps/web (NEXT_PUBLIC_SUPABASE_URL
# et NEXT_PUBLIC_SUPABASE_ANON_KEY), mais avec le préfixe EXPO_PUBLIC_ requis par Expo.
#
# Pour EAS Build (production), utiliser :
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "..."
